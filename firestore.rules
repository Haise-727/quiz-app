rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function hasRole(role) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read other profiles (needed for teacher grading display names).
    // Only the owner can write their own profile.
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── quizzes ───────────────────────────────────────────────────────────────
    // - Active quizzes are publicly readable (students/guests need to join by code).
    // - Creator can always read their own (even inactive).
    // - Only signed-in users (teachers) can create quizzes.
    // - Only the creator can update or delete.
    match /quizzes/{quizId} {
      allow read:   if resource.data.active == true ||
                       isOwner(resource.data.createdBy);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.createdBy);
      allow delete: if isOwner(resource.data.createdBy);
    }

    // ── quiz_results ──────────────────────────────────────────────────────────
    // - Anyone (including guests) can CREATE a result (guest submissions).
    // - A signed-in student can read their own results.
    // - The quiz's teacher can read all results for their quiz.
    // - Only the teacher can UPDATE a result (for manual grading).
    // - Nobody can delete results.
    match /quiz_results/{resultId} {
      allow create: if true;   // guests + students
      allow read:   if isOwner(resource.data.userId) ||
                       isOwner(resource.data.teacherId);
      allow update: if isOwner(resource.data.teacherId);
      allow delete: if false;
    }

    // ── classes ───────────────────────────────────────────────────────────────
    // - Any signed-in user can read (students need to look up a class by join code).
    // - Only the creating teacher can create/update/delete their own class.
    match /classes/{classId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(request.resource.data.teacherId);
      allow update: if isOwner(resource.data.teacherId);
      allow delete: if isOwner(resource.data.teacherId);
    }

    // ── class_enrollments ─────────────────────────────────────────────────────
    // - A student can create their own enrollment (joining a class).
    // - The enrolled student or the owning teacher can read/delete it.
    match /class_enrollments/{enrollmentId} {
      allow create: if isOwner(request.resource.data.studentId);
      allow read:   if isOwner(resource.data.studentId) ||
                       get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid;
      allow delete: if isOwner(resource.data.studentId) ||
                       get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid;
      allow update: if false;
    }

    // ── question_bank ─────────────────────────────────────────────────────────
    // Personal per-teacher saved questions — only the owning teacher can touch theirs.
    match /question_bank/{itemId} {
      allow read:   if isOwner(resource.data.teacherId);
      allow create: if isOwner(request.resource.data.teacherId);
      allow delete: if isOwner(resource.data.teacherId);
      allow update: if false;
    }

    // ── notifications ─────────────────────────────────────────────────────────
    // - Any signed-in user can create a notification for another user (e.g. teacher
    //   notifying a student that their submission was graded).
    // - Only the recipient can read/mark their own notifications as read.
    match /notifications/{notificationId} {
      allow read:   if isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId);
      allow delete: if false;
    }
  }
}
